# General
PROJECT_NAME=JobOS
ENV=development

# MongoDB
MONGO_URI=mongodb://root:example@mongodb:27017/jobos?authSource=admin

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=jobos
KEYCLOAK_CLIENT_ID=jobos-api
KEYCLOAK_CLIENT_SECRET=change-me

# Postgres (for Keycloak)
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=password

# Groq API
GROQ_API_KEY=REDACTED_GROQ_KEY_2

# Gemini API (kept for reference — no longer used)
# GEMINI_API_KEY=REDACTED_GOOGLE_KEY

# Email (Watcher — inbound IMAP)
EMAIL_HOST=imap.gmail.com
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-app-password

# Email (Notifications — outbound SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=JobOS <your-email@example.com>
